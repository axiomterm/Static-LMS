<?xml version="1.0" encoding="UTF-8"?>
<configuration>

  <!-- SQL Server connection used by App_Code/Db.cs. Integrated Security means the
       IIS Application Pool identity connects to SQL Server with its Windows account;
       switch to User ID/Password if you use SQL authentication. -->
  <connectionStrings>
    <add name="Training"
         connectionString="Server=MY-SERVER\INSTANCE;Database=Training;Integrated Security=SSPI;Encrypt=True;TrustServerCertificate=True"
         providerName="System.Data.SqlClient" />
  </connectionStrings>

  <system.webServer>
    <!-- Video MIME types (IIS doesn't always serve them by default).
         IIS handles Range requests over static files automatically,
         so video seeking works without extra configuration.
         clientCache NoControl: IIS doesn't set a cache header; the outboundRules decide it. -->
    <staticContent>
      <clientCache cacheControlMode="NoControl" />
      <remove fileExtension=".mp4" />
      <mimeMap fileExtension=".mp4" mimeType="video/mp4" />
      <remove fileExtension=".webm" />
      <mimeMap fileExtension=".webm" mimeType="video/webm" />
      <remove fileExtension=".ogv" />
      <mimeMap fileExtension=".ogv" mimeType="video/ogg" />
    </staticContent>

    <!-- Cache: HTML is never cached (it changes with every build); CSS/JS are cached for 1 year.
         The outboundRules require the "URL Rewrite" module installed in IIS. -->
    <httpProtocol>
      <customHeaders>
        <remove name="Cache-Control" />
      </customHeaders>
    </httpProtocol>
    <outboundRules>
      <rule name="no-cache HTML">
        <match serverVariable="RESPONSE_Cache_Control" pattern=".*" />
        <conditions>
          <add input="{REQUEST_URI}" pattern="\.(html)$" />
        </conditions>
        <action type="Rewrite" value="no-store" />
      </rule>
      <rule name="long cache CSS JS">
        <match serverVariable="RESPONSE_Cache_Control" pattern=".*" />
        <conditions>
          <add input="{REQUEST_URI}" pattern="\.(css|js)$" />
        </conditions>
        <action type="Rewrite" value="public, max-age=31536000, immutable" />
      </rule>
    </outboundRules>

    <defaultDocument>
      <files>
        <clear />
        <add value="index.html" />
      </files>
    </defaultDocument>

    <!-- Don't list folder contents -->
    <directoryBrowse enabled="false" />
  </system.webServer>

  <!-- Integrated Windows Authentication against the domain, plus ASP.NET settings.
       Requires the "Windows Authentication" feature installed in IIS and
       "Anonymous Authentication" DISABLED. customErrors hides stack traces from
       remote clients (the JSON endpoints just surface a 500 to the browser). -->
  <system.web>
    <authentication mode="Windows" />
    <authorization>
      <deny users="?" />   <!-- blocks unauthenticated users -->
    </authorization>
    <customErrors mode="RemoteOnly" />
  </system.web>

</configuration>
